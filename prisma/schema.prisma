generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ScanRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  type      String   // "NETWORK", "CODE", "PENTEST", "RECON"
  target    String
  status    String   // "COMPLETED", "FAILED"
  data      String   // SQLite doesn't support native JSON, so we'll store as string
  summary   String?  
  severity  String?  
}

model DiscoveredAsset {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  domain    String   @unique
  ip        String?
  source    String   
  lastSeen  DateTime @updatedAt
}
